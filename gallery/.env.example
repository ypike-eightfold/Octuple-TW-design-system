# Auth.js / NextAuth v5 secret.
# Generate with: openssl rand -base64 32
# Required in production. Optional in dev IF NEXT_PUBLIC_AUTH_BYPASS=true.
AUTH_SECRET=

# Google OAuth client.
# Create at https://console.cloud.google.com → APIs & Services → Credentials → OAuth client ID
# Authorized redirect URI: https://<your-deploy>/api/auth/callback/google
# See docs/google-oauth-setup.md for step-by-step.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Restricts who can sign in. Comma-separate for multiple. Defaults to eightfold.ai.
AUTH_ALLOWED_DOMAINS=eightfold.ai

# Set to "true" to skip auth entirely (useful locally before OAuth is set up).
# NEVER set this in production.
NEXT_PUBLIC_AUTH_BYPASS=true
